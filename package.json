  "scripts": {
    "start": "npm run build:server && concurrently -k \"npm run server\" \"npm run client\"",
    "server": "cross-env NODE_OPTIONS='--max-old-space-size=4096' node server/dist/server/src/server.js",
    "worker": "cross-env NODE_OPTIONS='--max-old-space-size=4096' node server/dist/server/src/worker.js",
    "start:dev": "concurrently -k \"npm run server:dev\" \"npm run client\"",
    "server:dev": "cross-env NODE_OPTIONS='--max-old-space-size=2048' nodemon server/src/server.ts",
    "worker:dev": "cross-env NODE_OPTIONS='--max-old-space-size=2048' nodemon server/src/worker.ts",
    "client": "vite",
    "build": "vite build",
    "build:server": "tsc -p server/tsconfig.json",
    "preview": "vite preview",
    "lint": "eslint src server/src chrome-extension/src e2e playwright.config.ts vitest.config.ts",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:watch": "vitest",
    "mcp:build": "tsc --project server/tsconfig.mcp.json",
    "browser:service": "npm run build --prefix browser && npm run start --prefix browser",
    "browser:service:dev": "npm run dev --prefix browser",
    "camoufox:server": "python server/src/services/camoufox-server.py",
    "camoufox:server:win": "py -3 server/src/services/camoufox-server.py",
    "playwright:install": "npx playwright@1.58.0 install chromium"
  },
  "overrides": {
    "playwright-core": "1.58.0"
  },
