{
  "manifest_version": 3,
  "name": "Scout-X Scrapper",
  "version": "1.0.0",
  "description": "Visual web scraping: extract lists, tables, and text from any page. Scout-X Scrapper.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "tabs",
    "sidePanel",
    "downloads",
    "notifications"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "service-worker-loader.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "src/sidepanel/index.html"
  },
  "action": {
    "default_title": "Scout-X Scrapper",
    "default_icon": {
      "16": "src/public/icons/scoutx-logo.png",
      "32": "src/public/icons/scoutx-logo.png",
      "48": "src/public/icons/scoutx-logo.png",
      "128": "src/public/icons/scoutx-logo.png"
    }
  },
  "content_scripts": [
    {
      "js": [
        "assets/index.ts-loader-CSpmY4wg.js"
      ],
      "matches": [
        "http://*/*",
        "https://*/*"
      ],
      "css": [
        "src/content/content.css"
      ],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "icons": {
    "16": "src/public/icons/scoutx-logo.png",
    "32": "src/public/icons/scoutx-logo.png",
    "48": "src/public/icons/scoutx-logo.png",
    "128": "src/public/icons/scoutx-logo.png"
  },
  "web_accessible_resources": [
    {
      "matches": [
        "<all_urls>"
      ],
      "resources": [
        "src/datatable/index.html"
      ],
      "use_dynamic_url": false
    },
    {
      "matches": [
        "http://*/*",
        "https://*/*"
      ],
      "resources": [
        "assets/messages-D0e9mEno.js",
        "assets/index.ts-eJ6B7omd.js"
      ],
      "use_dynamic_url": false
    }
  ]
}
